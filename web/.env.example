# FOGO Pulse Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# PYTH LAZER ACCESS TOKEN (REQUIRED for epoch creation)
# =============================================================================
# Get your access token from: https://pyth.network/developers
# This token is used SERVER-SIDE only (not exposed to browser)
# The /api/pyth-price route uses this to fetch signed price messages
PYTH_ACCESS_TOKEN=

# =============================================================================
# OPTIONAL: Override default RPC endpoint
# =============================================================================
# Default: https://testnet.fogo.io
# NEXT_PUBLIC_FOGO_RPC_URL=https://testnet.fogo.io
