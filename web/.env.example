# FOGO Pulse Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# PYTH LAZER ACCESS TOKEN (REQUIRED for epoch creation)
# =============================================================================
# Get your access token from: https://pyth.network/developers
# This token is used SERVER-SIDE only (not exposed to browser)
# The /api/pyth-price route uses this to fetch signed price messages
PYTH_ACCESS_TOKEN=

# =============================================================================
# USDC FAUCET MINT AUTHORITY (REQUIRED for /faucet page)
# =============================================================================
# JSON byte array of the mint authority keypair for the testnet USDC mint
# This is SERVER-SIDE only (not exposed to browser)
# Example: [1,2,3,...,64]
FAUCET_PRIVATE_KEY=

# =============================================================================
# FIREBASE (REQUIRED for /feedback page)
# =============================================================================
# Firebase Admin SDK service account key as a JSON string
# This is SERVER-SIDE only (not exposed to browser)
# Get from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT_KEY=

# =============================================================================
# FEEDBACK SETTINGS (OPTIONAL)
# =============================================================================
# Comma-separated base58 wallet public keys for admin access
ADMIN_WALLETS=
# Max issues per wallet per hour (default: 5)
FEEDBACK_RATE_LIMIT=5

# =============================================================================
# OPTIONAL: Override default RPC endpoint
# =============================================================================
# Default: https://testnet.fogo.io
# NEXT_PUBLIC_FOGO_RPC_URL=https://testnet.fogo.io
