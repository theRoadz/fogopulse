# Anchor Scripts Environment Variables
# Copy this file to .env and update values

# Pyth Lazer API access token (required for create-test-epoch.ts)
# Get a token from: https://pyth.network/developers
PYTH_ACCESS_TOKEN=

# Wallet path (optional - defaults to ~/.config/solana/fogo-testnet.json)
# WALLET_PATH=/path/to/your/wallet.json
