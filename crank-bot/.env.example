# FogoPulse Crank Bot Configuration

# Required: Pyth Lazer API access token
# Get from https://pyth.network/developers
PYTH_ACCESS_TOKEN=

# Optional: Path to wallet keypair (default: ~/.config/solana/fogo-testnet.json)
# WALLET_PATH=/path/to/wallet.json

# Optional: Poll interval in seconds (default: 10)
# POLL_INTERVAL_SECONDS=10

# Optional: RPC URL (default: https://testnet.fogo.io)
# RPC_URL=https://testnet.fogo.io

# Optional: Pools to monitor - comma-separated (default: BTC,ETH,SOL,FOGO)
# Runs independent concurrent runners for each pool.
# POOL_ASSETS=BTC,ETH,SOL,FOGO

# Optional: Legacy single-pool mode (used if POOL_ASSETS is not set)
# POOL_ASSET=BTC

# Optional: Log level - debug, info, warn, error (default: info)
# LOG_LEVEL=info

# Optional: Auto-create epochs when none exists (default: true)
# Set to 'false' to disable - bot will only advance/settle existing epochs
# AUTO_CREATE_EPOCH=true

# Optional: Poll interval when no epoch is running (default: 180 = 3 minutes)
# IDLE_POLL_INTERVAL_SECONDS=180

# Optional: Seconds past end_time before timeout force-close (default: 60)
# Must match GlobalConfig.settlement_timeout_seconds on-chain
# SETTLEMENT_TIMEOUT_SECONDS=60

# =============================================================================
# Trade Simulation Bot (trade-bot.ts)
# =============================================================================

# Required: Master on/off switch (default: false)
# TRADE_BOT_ENABLED=true

# Optional: Number of bot wallets (default: 5)
# TRADE_BOT_COUNT=5

# Optional: Min trade amount in USDC (default: 0.5)
# TRADE_BOT_MIN_AMOUNT=0.5

# Optional: Max trade amount in USDC (default: 5.0)
# TRADE_BOT_MAX_AMOUNT=5.0

# Optional: Max trades per bot per epoch (default: 2)
# TRADE_BOT_MAX_TRADES_PER_EPOCH=2

# Optional: Directory for bot wallet keypairs (default: ./trade-bot-wallets)
# TRADE_BOT_WALLETS_DIR=./trade-bot-wallets

# Optional: Poll interval in seconds for trade bot (default: 10)
# TRADE_BOT_POLL_INTERVAL_SECONDS=10
